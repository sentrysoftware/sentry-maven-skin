	"scripts": {
		"format": "prettier --write \"src/**/*.{js,cjs,mjs,css,scss,html,xml,yml,yaml,json,md}\" \"tests/**/*.js\" \"tools/**/*.js\" \"*.{js,cjs,md,yaml,yml,json}\"",
		"format:check": "prettier --check \"src/**/*.{js,cjs,mjs,css,scss,html,xml,yml,yaml,json,md}\" \"tests/**/*.js\" \"tools/**/*.js\" \"*.{js,cjs,md,yaml,yml,json}\"",
		"lint": "eslint src/main/webapp/js/*.js",
		"lint:fix": "eslint --fix src/main/webapp/js/*.js",
		"ui:baseline:install": "playwright install chromium",
		"ui:baseline:capture": "node tools/ui-baseline/run.js capture",
		"ui:baseline:verify": "node tools/ui-baseline/run.js verify",
		"ui:baseline:compare": "node tools/ui-baseline/run.js compare"
	},
	"engines": {
		"node": ">=18.0.0"
